# Normaliza line endings para LF no repositório
* text=auto eol=lf

# Arquivos que devem sempre ser LF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.qss text eol=lf
*.env text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.toml text eol=lf

# Arquivos binários (não normalizar)
*.png binary
*.ico binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ttf binary
*.exe binary
*.db binary
*.enc binary
*.docx binary
