# ==========================================
# PostgreSQL - Banco de Dados
# ==========================================
# Opcao 1: URL completa (recomendado para producao)
# MEDCONTRACT_DATABASE_URL=postgresql://usuario:senha@host:5432/database?sslmode=require

# Opcao 2: Configuracoes individuais
MEDCONTRACT_DB_HOST=localhost
MEDCONTRACT_DB_PORT=5432
MEDCONTRACT_DB_NAME=medcontract
MEDCONTRACT_DB_USER=postgres
MEDCONTRACT_DB_PASSWORD=TROQUE_ESTA_SENHA
# Em producao, use require/verify-ca/verify-full.
# Para banco local de desenvolvimento, "prefer" tambem funciona.
MEDCONTRACT_DB_SSLMODE=prefer
MEDCONTRACT_DB_CONNECT_TIMEOUT=10
MEDCONTRACT_DB_BACKEND=auto
MEDCONTRACT_DB_ALLOW_SQLITE_FALLBACK=1

# Pool de conexoes
MEDCONTRACT_DB_POOL_ENABLED=1
MEDCONTRACT_DB_POOL_MAX=8

# ==========================================
# Migracao automatica SQLite -> PostgreSQL
# ==========================================
MEDCONTRACT_AUTO_MIGRATE_SQLITE=0

# ==========================================
# SMTP - Envio de E-mails
# ==========================================
MEDCONTRACT_SMTP_HOST=smtp.gmail.com
MEDCONTRACT_SMTP_PORT=587
MEDCONTRACT_SMTP_USER=seu_email@gmail.com
MEDCONTRACT_SMTP_PASSWORD=TROQUE_PELA_SENHA_DE_APP
MEDCONTRACT_SMTP_FROM=seu_email@gmail.com
MEDCONTRACT_SMTP_FROM_NAME=MedContract
MEDCONTRACT_SMTP_USE_TLS=1
MEDCONTRACT_SMTP_USE_SSL=0
MEDCONTRACT_SMTP_TIMEOUT=20

# ==========================================
# Seguranca
# ==========================================
MEDCONTRACT_ENV=production
MEDCONTRACT_REQUIRE_BOOTSTRAP_USERS=1
MEDCONTRACT_DEFAULT_ADMIN_USER=admin
MEDCONTRACT_DEFAULT_ADMIN_PASSWORD=DEFINA_UMA_SENHA_FORTE
MEDCONTRACT_DEFAULT_RECEPCAO_USER=recepcao
MEDCONTRACT_DEFAULT_RECEPCAO_PASSWORD=
MEDCONTRACT_ALLOW_LEGACY_PLAINTEXT_LOGIN=0
MEDCONTRACT_LOGIN_MAX_ATTEMPTS=5
MEDCONTRACT_LOGIN_LOCKOUT_SECS=60
# Em build (exe) o preflight já pode ser estrito por padrão.
MEDCONTRACT_SECURITY_PREFLIGHT_STRICT=0

# ==========================================
# Performance e Cache
# ==========================================
MEDCONTRACT_DASHBOARD_CACHE_TTL=15
MEDCONTRACT_FINANCEIRO_CACHE_TTL=10
MEDCONTRACT_PERF_MODE=0

# ==========================================
# Backup
# ==========================================
MEDCONTRACT_BACKUP_RETENTION_DAYS=30
MEDCONTRACT_AUTO_BACKUP_ON_STARTUP=0
MEDCONTRACT_AUTO_BACKUP_ON_EXIT=0
MEDCONTRACT_ALLOW_JSON_BACKUP_FALLBACK=0
# Opcional: chave para criptografar backups gerados em repouso.
# Aceita chave Fernet (base64 urlsafe) ou texto simples (derivado internamente).
MEDCONTRACT_BACKUP_ENCRYPTION_KEY=

# ==========================================
# Recursos Avancados
# ==========================================
MEDCONTRACT_FORCE_SCHEMA_CHECK=0


